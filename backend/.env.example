# ============================================================================
# Multimodal Deepfake Detection System - Environment Variables
# ============================================================================
# Copy this file to .env and update values as needed
# ============================================================================

# Application Settings
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# File Upload Limits (in MB)
MAX_IMAGE_SIZE_MB=100
MAX_VIDEO_SIZE_MB=100
MAX_AUDIO_SIZE_MB=100

# Device for PyTorch (cpu, cuda, or mps)
DEVICE=cuda

# Video Processing Settings
VIDEO_FPS_SAMPLE_RATE=1
MAX_FRAMES_TO_PROCESS=100

# Audio Processing Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_SEGMENT_DURATION=4

# Security
SECRET_KEY=your-secret-key-change-in-production-use-at-least-32-chars
RATE_LIMIT=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database (for future use)
# DATABASE_URL=sqlite:///./deepfake_detection.db

# Redis Cache (for future use)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=3600
